{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug AppHost (Aspire)",
      "type": "dotnet",
      "request": "launch",
      "projectPath": "${workspaceFolder}/apps/api/src/{ProjectName}.AppHost/{ProjectName}.AppHost.csproj"
    },
    {
      "name": "Debug WebApi (standalone)",
      "type": "dotnet",
      "request": "launch",
      "projectPath": "${workspaceFolder}/apps/api/src/{ProjectName}.WebApi/{ProjectName}.WebApi.csproj"
    },
    {
      "name": "Attach to Next.js (port 9229)",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "skipFiles": ["<node_internals>/**"]
    }
  ],
  "compounds": [
    {
      "name": "Aspire + Next.js debug",
      "configurations": [
        "Debug AppHost (Aspire)",
        "Attach to Next.js (port 9229)"
      ],
      "stopAll": true
    }
  ]
}
